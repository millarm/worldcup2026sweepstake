# Replit configuration — World Cup 2026 Sweepstake
# Click "Run" to install dependencies and start the Flask server.
run = "pip install -q -r requirements.txt && python3 app.py"
entrypoint = "app.py"
modules = ["python-3.11:v1"]

[nix]
channel = "stable-24_05"

[env]
PORT = "8080"
# Pull real results on first boot and keep updating automatically.
WC_AUTOSEED = "1"
WC_FEED_AUTO = "1"
WC_FEED_INTERVAL = "900"          # background poll every 15 minutes
# Live results come from ESPN's public API by default (no key needed).
# WC_FEED_SOURCE = "sample"       # use the bundled demo data instead
# The admin panel is password-protected (built-in default). Override here:
# ADMIN_PASSWORD = "choose-your-own"
# Optional: set FOOTBALL_DATA_API_KEY (football-data.org) for an alternate source.

[deployment]
run = ["sh", "-c", "python3 app.py"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[userenv]

[userenv.shared]
WC_FEED_SCHEDULED = "1"
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
